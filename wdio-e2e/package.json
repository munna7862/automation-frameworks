{
  "name": "wdio-e2e",
  "version": "1.0.0",
  "description": "WebdriverIO E2E automation framework migrated from playwright-e2e.",
  "main": "index.js",
  "scripts": {
    "test:interop": "cross-env ENVIRONMENT=INTEROP TZ=Australia/Adelaide wdio run src/config/wdio.conf.ts",
    "test": "wdio run src/config/wdio.conf.ts",
    "generate-allure": "allure generate --clean reports/allure-results -o reports/allure-report",
    "open-allure": "allure open reports/allure-report",
    "report": "npm run generate-allure && npm run open-allure",
    "clean-reports": "rimraf reports logs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.10",
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "allure-commandline": "^2.34.1",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "winston": "^3.19.0"
  }
}
